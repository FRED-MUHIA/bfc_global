<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep Laravel's public directory out of visible URLs.
    RewriteCond %{THE_REQUEST} \s/+public/([^\s?]*) [NC]
    RewriteRule ^public/(.*)$ /$1 [R=301,L]

    # Serve the Laravel public directory when the hosting document root is the project root.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
